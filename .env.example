# API Configuration
# Leave blank or use /api for Vercel deployment
# Use http://localhost:3001/api for local development with the backend server
VITE_API_URL=/api

# Supabase Direct Connection Configuration
# Add these values if you want to connect directly to Supabase rather than localhost/Vercel functions
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
